NODE_ENV=development
PORT=3001
API_PREFIX=api

LOG_LEVEL=debug
LOG_PRETTY=true

DATABASE_URL="file:./prisma/dev.db"

REQUEST_TIMEOUT_MS=15000

HTTP_CLIENT_TIMEOUT_MS=10000
HTTP_CLIENT_RETRY_COUNT=1
HTTP_CLIENT_RETRY_DELAY_MS=300

HEALTH_MEMORY_HEAP_MB=256
HEALTH_MEMORY_RSS_MB=512
HEALTH_DISK_THRESHOLD_PERCENT=0.9

I18N_FALLBACK_LANGUAGE=zh
