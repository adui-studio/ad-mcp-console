{
  "name": "ad-mcp-console",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "MCP Console is a developer-focused web UI for connecting, exploring, invoking, and sharing MCP servers.",
  "author": "adui-studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adui-studio/ad-mcp-console.git"
  },
  "homepage": "https://github.com/adui-studio/ad-mcp-console",
  "bugs": {
    "url": "https://github.com/adui-studio/ad-mcp-console/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "developer-tools",
    "console",
    "web-ui",
    "ai-tools",
    "typescript",
    "monorepo",
    "nest",
    "react"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck:web": "pnpm --filter web exec tsc -b",
    "typecheck:api": "pnpm --filter api exec tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:api",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "turbo": "^2.8.21",
    "typescript-eslint": "^8.57.2"
  }
}
